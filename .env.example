NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_PROJECT_ID=
OPENAI_API_KEY=

# Form monitoring automation
FORM_CHECK_CRON=*/30 * * * *
FORM_CHECK_RUN_ON_START=false
FORM_CHECK_SITES_PATH=scripts/form-sites.json
FORM_CHECK_EMAIL_FROM=
FORM_CHECK_EMAIL_TO=
# Option A (preferred): full SMTP URL, e.g. smtp://user:pass@smtp.example.com:587
FORM_CHECK_SMTP_URL=
# Option B: individual SMTP values
FORM_CHECK_SMTP_HOST=
FORM_CHECK_SMTP_PORT=587
FORM_CHECK_SMTP_SECURE=false
FORM_CHECK_SMTP_USER=
FORM_CHECK_SMTP_PASS=
